APP_NAME="QR Attendance"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
# School calendar & "today" schedules use this timezone (Philippines).
APP_TIMEZONE=Asia/Manila
#
# Phones / QR camera: browsers only allow the camera on HTTPS (or localhost).
# Plain http://YOUR_LAN_IP:8000 will NOT work for scanning.
# Offline LAN: use Caddy (Caddyfile) or Apache SSL → APP_URL=https://YOUR_LAN_IP:9443,
# SESSION_SECURE_COOKIE=true, php artisan config:clear. See README.
# With internet only: cloudflared tunnel --url http://127.0.0.1:8000 and set APP_URL to the trycloudflare URL.
#
# Optional: pin your PC LAN IPv4 for scripts/start-dev-stack.ps1 and Caddy when auto-detect fails.
# DEV_LAN_IP=192.168.1.10
#
# Optional: URL the desktop shortcut opens (overrides APP_URL for the launcher only).
# LAN_HTTPS_PORT=9443
# DEV_OPEN_URL=https://192.168.1.10:9443

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

# Comma-separated proxy IPs for X-Forwarded-* (see README “Deploy online”).
# Local Caddy: TRUSTED_PROXIES=127.0.0.1,::1
# Vercel / hosted TLS proxy: TRUSTED_PROXIES=*
# TRUSTED_PROXIES=127.0.0.1,::1

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# SQLite (default in .env.example). For XAMPP MySQL, use:
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=qr_attendance_db
# DB_USERNAME=root
# DB_PASSWORD=

DB_CONNECTION=sqlite
# Optional: single URL for MySQL/Postgres (reads DATABASE_URL or DB_URL).
# DB_URL=
# DATABASE_URL=
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# Leave unset for mixed access: http://127.0.0.1:8000 on PC + https://LAN:9443 on phones.
# The app sets the session cookie Secure flag from each request (see ConfigureSessionSecureCookie).
# Only set SESSION_SECURE_COOKIE=true/false if you need to force it (e.g. all-HTTPS production).
# SESSION_SECURE_COOKIE=

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
